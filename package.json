{
  "name": "hedera-vnx-wv-carbon-swarm",
  "version": "0.1.0",
  "description": "VNX BitLattice Verification Swarm for West Virginia energy production & usage data — end-to-end verified carbon credit retirement on Hedera (HCS Vera Lattice + cryptographic receipts)",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src/",
    "dist/scripts/",
    "docs/",
    "data/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "vnx-wv-demo": "./dist/scripts/vnx-wv-energy-demo.js",
    "vnx-wv-verify": "./dist/scripts/vnx-wv-verify-receipt.js",
    "vnx-wv-hcs": "./dist/scripts/hcs-wv-publish.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --verbose",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "demo:plan": "tsx scripts/vnx-wv-energy-demo.ts --plan-only",
    "demo:live": "tsx scripts/vnx-wv-energy-demo.ts --live",
    "verify": "tsx scripts/vnx-wv-verify-receipt.ts",
    "demo:hcs": "tsx scripts/hcs-wv-publish.ts",
    "lint": "eslint src/ scripts/ tests/",
    "lint:fix": "eslint src/ scripts/ tests/ --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/ coverage/ .tsbuildinfo"
  },
  "keywords": [
    "hedera",
    "hiero",
    "hbar",
    "vnx",
    "bitlattice",
    "verification-swarm",
    "agent-swarm",
    "carbon-credit",
    "retirement",
    "west-virginia",
    "energy",
    "eia",
    "cryptographic-proof",
    "verifiable-receipt",
    "hcs",
    "vera-lattice",
    "typescript"
  ],
  "author": "Vera Lattice <vera@lattice.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/livevnx8/hedera-vnx-wv-carbon-swarm.git"
  },
  "dependencies": {
    "@hashgraph/sdk": "^2.60.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
